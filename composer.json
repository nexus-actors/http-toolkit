{
  "name": "nexus-actors/http-toolkit",
  "description": "Production essentials for Nexus HTTP: in-process test client, structured access logging, W3C trace-context propagation, body size limit, health checks.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.5.7",
    "ext-ctype": "*",
    "nexus-actors/http": "self.version",
    "nexus-actors/http-ws": "self.version",
    "nexus-actors/logger": "dev-main",
    "nyholm/psr7": "^1.8",
    "phpunit/phpunit": "^13.0",
    "psr/http-factory": "^1.1",
    "psr/http-message": "^2.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-server-middleware": "^1.0",
    "psr/log": "^3.0"
  },
  "autoload": { "psr-4": { "Monadial\\Nexus\\Http\\Toolkit\\": "src/" } },
  "autoload-dev": { "psr-4": { "Monadial\\Nexus\\Http\\Toolkit\\Tests\\": "tests/" } },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": { "sort-packages": true }
}
